<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:security="http://www.springframework.org/schema/security"
	xsi:schemaLocation="http://www.springframework.org/schema/security http://www.springframework.org/schema/security/spring-security.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<security:http auto-config="true" use-expressions="true">
		<security:intercept-url pattern="/**"
			access="permitAll" />

		<security:csrf disabled="true" />

		<security:form-login login-page="/member/login"
			login-processing-url="/member/login" default-target-url="/"
			authentication-failure-url="/member/login?error" />

		<security:logout logout-url="/member/logout"
			logout-success-url="/" invalidate-session="true"
			delete-cookies="JSESSIONID" />
	</security:http>

	<security:authentication-manager>
		<security:authentication-provider>
			<security:jdbc-user-service
    data-source-ref="dataSource"
    users-by-username-query="SELECT userid, userpw, 1 as enabled FROM tbl_member WHERE userid = ?"
    authorities-by-username-query="SELECT userid, auth FROM tbl_member_auth WHERE userid = ?" />

			<security:password-encoder
				ref="bcryptPasswordEncoder" />
		</security:authentication-provider>
	</security:authentication-manager>

</beans>