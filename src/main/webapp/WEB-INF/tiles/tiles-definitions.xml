		<put-attribute name="title" value="" />
		<put-attribute name="title" value="" />
		<put-attribute name="header"
			value="/WEB-INF/views/layout/header.jsp" />
		<put-attribute name="menu"
			value="/WEB-INF/views/layout/menu.jsp" />
		<put-attribute name="body" value="" />
		<put-attribute name="footer"
			value="/WEB-INF/views/layout/footer.jsp" />
	</definition>

	<definition name="member/profile" extends="baseLayout">
		<put-attribute name="showBanner" value="false" />
		<put-attribute name="title" value="내 프로필 - 광고 없음" />
		<put-attribute name="body"
			value="/WEB-INF/views/member/profile.jsp" />
