	<definition name="board/get" extends="baseLayout">
		<put-attribute name="title" value="글 상세보기" />
		<put-attribute name="body"
			value="/WEB-INF/views/board/get.jsp" />
	</definition>

	<definition name="board/modify" extends="baseLayout">
		<put-attribute name="title" value="글 수정하기" />
		<put-attribute name="body"
			value="/WEB-INF/views/board/modify.jsp" />
